# ============================================================
# SynthDetect Environment Configuration
# Copy to .env and fill in actual values: cp .env.example .env
# ============================================================

# API Keys
GOOGLE_API_KEY=your-google-api-key-here

# LLM Configuration
DEFAULT_LLM_PROVIDER=google
DEFAULT_MODEL=gemini-2.5-flash

# Detection Thresholds
DR_SIMILARITY_THRESHOLD=0.85
FAID_CONFIDENCE_THRESHOLD=0.65

# Storage (lightweight - SQLite + file cache)
DATABASE_URL=sqlite:///data/synthdetect.db
CACHE_DIR=data/cache
ENABLE_CACHE=true
CACHE_TTL_SECONDS=86400

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/synthdetect.log

# Performance (tuned for M1 8GB)
MAX_TEXT_LENGTH=5000
BATCH_SIZE=8
TIMEOUT_SECONDS=30

# Development
DEBUG=true
TESTING=false
SEED=42
